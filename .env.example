NODE_ENV=development
APP_NAME=Bookora API
IMAGE_TAG=latest
PORT=8000
API_PREFIX=api
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
TRUST_PROXY=false
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=ecommerce_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecommerce_db?schema=public
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
REFRESH_TOKEN_HASH_SECRET=change-me-refresh-token-hash-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=
COOKIE_SECRET=change-me-cookie-secret
AUTH_EMAIL_MAX_FAILED_ATTEMPTS=5
AUTH_EMAIL_LOCK_SECONDS=60
AUTH_IP_MAX_FAILED_ATTEMPTS=10
AUTH_IP_LOCK_SECONDS=120
AUTH_ATTEMPT_WINDOW_SECONDS=60
AUTH_LOGIN_THROTTLE_TTL_SECONDS=60
AUTH_LOGIN_THROTTLE_LIMIT=30
AUTH_REGISTER_TTL_SECONDS=60
AUTH_REGISTER_LIMIT=10
AUTH_REFRESH_TTL_SECONDS=60
AUTH_REFRESH_LIMIT=10
AUTH_CSRF_TTL_SECONDS=60
AUTH_CSRF_LIMIT=10
GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_CLIENT_SECRET=change-me-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_SITEVERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

STORAGE_PROVIDER=r2
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=bookora-public
R2_PRIVATE_BUCKET=bookora
R2_PUBLIC_BASE_URL=
IMAGE_UPLOAD_MAX_BYTES=5242880
IMAGE_MAX_WIDTH=2400
IMAGE_MAX_HEIGHT=2400
IMAGE_WEBP_QUALITY=82

STORAGE_PROVIDER=r2
R2_ENDPOINT=
R2_REGION=auto
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BUCKET=bookora-public
R2_PRIVATE_BUCKET=bookora-public
R2_PUBLIC_BASE_URL=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REDIS_URL=

# Server-only VietMap Search/Geocoding credentials. Never expose as VITE_*.
VIETMAP_SERVICE_KEY=
VIETMAP_API_BASE_URL=https://maps.vietmap.vn/api

# Server-only GHN credentials. Never expose as VITE_*.
GHN_BASE_URL=https://dev-online-gateway.ghn.vn/shiip/public-api
GHN_TOKEN=
GHN_SHOP_ID=
GHN_CLIENT_ID=
GHN_TIMEOUT_MS=8000
GHN_DEFAULT_ITEM_WEIGHT_GRAMS=500
GHN_DEFAULT_PACKAGE_LENGTH_CM=20
GHN_DEFAULT_PACKAGE_WIDTH_CM=15
GHN_DEFAULT_PACKAGE_HEIGHT_CM=5

# Server-only VNPAY Sandbox credentials.
VNPAY_ENV=sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_QUERY_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_RETURN_URL=http://localhost:8000/api/v1/payments/vnpay/return
VNPAY_FRONTEND_RESULT_URL=http://localhost:5173/checkout/payment-result
VNPAY_IPN_URL=http://localhost:8000/api/v1/payments/vnpay/ipn
VNPAY_VERSION=2.1.0
VNPAY_COMMAND=pay
VNPAY_CURRENCY=VND
VNPAY_LOCALE=vn
VNPAY_ORDER_TYPE=other
VNPAY_PAYMENT_EXPIRE_MINUTES=15
