NODE_ENV=production
APP_NAME=Bookora API
DOCKERHUB_USERNAME=your-dockerhub-username
PORT=3000
API_PREFIX=api
FRONTEND_URL=https://bookora.example.com
CORS_ORIGIN=https://bookora.example.com

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=ecommerce_db
DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgres:5432/ecommerce_db?schema=public

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
REFRESH_TOKEN_HASH_SECRET=change-me-refresh-token-hash-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_DOMAIN=
COOKIE_SECRET=change-me-cookie-secret

AUTH_EMAIL_MAX_FAILED_ATTEMPTS=5
AUTH_EMAIL_LOCK_SECONDS=60
AUTH_IP_MAX_FAILED_ATTEMPTS=10
AUTH_IP_LOCK_SECONDS=120
AUTH_ATTEMPT_WINDOW_SECONDS=60
AUTH_LOGIN_THROTTLE_TTL_SECONDS=60
AUTH_LOGIN_THROTTLE_LIMIT=30
AUTH_REGISTER_TTL_SECONDS=60
AUTH_REGISTER_LIMIT=10
AUTH_REFRESH_TTL_SECONDS=60
AUTH_REFRESH_LIMIT=10
AUTH_CSRF_TTL_SECONDS=60
AUTH_CSRF_LIMIT=10

GOOGLE_CLIENT_ID=change-me-google-client-id
GOOGLE_CLIENT_SECRET=change-me-google-client-secret
GOOGLE_CALLBACK_URL=https://api.bookora.example.com/api/v1/auth/google/callback
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_SITEVERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change-me-minio-root-password
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=change-me-minio-root-password
MINIO_BUCKET=uploads
MINIO_USE_SSL=false
