model PaymentTransaction {
  id                       String                   @id @default(ulid())
  paymentId                String                   @map("payment_id")
  provider                 PaymentProvider          @default(VNPAY)
  status                   PaymentTransactionStatus @default(PENDING)
  amount                   Decimal                  @db.Decimal(12, 2)
  currency                 String                   @default("VND")
  idempotencyKey           String                   @unique @map("idempotency_key")
  merchantTxnRef           String                   @unique @map("merchant_txn_ref")
  providerTransactionNo    String?                  @map("provider_transaction_no")
  bankCode                 String?                  @map("bank_code")
  cardType                 String?                  @map("card_type")
  responseCode             String?                  @map("response_code")
  transactionStatus        String?                  @map("transaction_status")
  secureHashVerified       Boolean                  @default(false) @map("secure_hash_verified")
  requestPayloadSanitized  Json?                    @map("request_payload_sanitized")
  callbackPayloadSanitized Json?                    @map("callback_payload_sanitized")
  expiresAt                DateTime?                @map("expires_at")
  payDate                  DateTime?                @map("pay_date")
  callbackReceivedAt       DateTime?                @map("callback_received_at")
  stockReservedAt          DateTime?                @map("stock_reserved_at")
  stockReleasedAt          DateTime?                @map("stock_released_at")
  stockConsumedAt          DateTime?                @map("stock_consumed_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provider, providerTransactionNo])
  @@index([paymentId, status])
  @@index([status])
  @@index([expiresAt])
  @@map("payment_transactions")
}
