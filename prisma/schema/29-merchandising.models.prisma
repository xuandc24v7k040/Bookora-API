model RelatedProduct {
  id               String @id @default(ulid())
  productId        String @map("product_id")
  relatedProductId String @map("related_product_id")
  sortOrder        Int    @default(0) @map("sort_order")

  product        Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("RelatedTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@index([productId])
  @@index([relatedProductId])
  @@map("related_products")
}

model Combo {
  id          String    @id @default(ulid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?   @map("image_url")
  comboPrice  Decimal   @map("combo_price") @db.Decimal(12, 2)
  startAt     DateTime? @map("start_at")
  endAt       DateTime? @map("end_at")
  isActive    Boolean   @default(true) @map("is_active")

  items      ComboItem[]
  branches   ComboBranch[]
  orderItems OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isActive, startAt, endAt])
  @@map("combos")
}

model ComboItem {
  id        String @id @default(ulid())
  comboId   String @map("combo_id")
  variantId String @map("variant_id")
  quantity  Int

  combo   Combo          @relation(fields: [comboId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([comboId, variantId])
  @@index([comboId])
  @@index([variantId])
  @@map("combo_items")
}

model ComboBranch {
  id       String @id @default(ulid())
  comboId  String @map("combo_id")
  branchId String @map("branch_id")

  combo  Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([comboId, branchId])
  @@index([comboId])
  @@index([branchId])
  @@map("combo_branches")
}

model BookSeries {
  id          String  @id @default(ulid())
  name        String
  slug        String  @unique
  description String?

  items BookSeriesItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@map("book_series")
}

model BookSeriesItem {
  id        String  @id @default(ulid())
  seriesId  String  @map("series_id")
  productId String  @map("product_id")
  volumeNo  Int     @map("volume_no")
  title     String?

  series  BookSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([seriesId, productId])
  @@unique([seriesId, volumeNo])
  @@index([seriesId])
  @@index([productId])
  @@map("book_series_items")
}

model Preorder {
  id               String         @id @default(ulid())
  userId           String         @map("user_id")
  branchId         String         @map("branch_id")
  variantId        String         @map("variant_id")
  quantity         Int
  status           PreorderStatus @default(PENDING)
  note             String?
  convertedOrderId String?        @map("converted_order_id")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  convertedOrder Order?         @relation(fields: [convertedOrderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([branchId])
  @@index([variantId])
  @@index([convertedOrderId])
  @@index([status])
  @@map("preorders")
}

model BookPreview {
  id        String  @id @default(ulid())
  productId String  @map("product_id")
  title     String?
  fileUrl   String? @map("file_url")
  isActive  Boolean @default(true) @map("is_active")

  product Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  pages   BookPreviewPage[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([productId])
  @@index([isActive])
  @@map("book_previews")
}

model BookPreviewPage {
  id        String @id @default(ulid())
  previewId String @map("preview_id")
  pageNo    Int    @map("page_no")
  imageUrl  String @map("image_url")

  preview BookPreview @relation(fields: [previewId], references: [id], onDelete: Cascade)

  @@unique([previewId, pageNo])
  @@index([previewId])
  @@map("book_preview_pages")
}
