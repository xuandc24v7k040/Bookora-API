model RelatedProduct {
  id               String @id @default(ulid())
  productId        String
  relatedProductId String
  sortOrder        Int    @default(0)

  product        Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("RelatedTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@index([productId])
  @@index([relatedProductId])
  @@map("related_products")
}

model Combo {
  id          String    @id @default(ulid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  comboPrice  Decimal   @db.Decimal(12, 2)
  startAt     DateTime?
  endAt       DateTime?
  isActive    Boolean   @default(true)

  items      ComboItem[]
  branches   ComboBranch[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive, startAt, endAt])
  @@map("combos")
}

model ComboItem {
  id        String @id @default(ulid())
  comboId   String
  variantId String
  quantity  Int

  combo   Combo          @relation(fields: [comboId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([comboId, variantId])
  @@index([comboId])
  @@index([variantId])
  @@map("combo_items")
}

model ComboBranch {
  id       String @id @default(ulid())
  comboId  String
  branchId String

  combo  Combo  @relation(fields: [comboId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([comboId, branchId])
  @@index([comboId])
  @@index([branchId])
  @@map("combo_branches")
}

model BookSeries {
  id          String  @id @default(ulid())
  name        String
  slug        String  @unique
  description String?

  items BookSeriesItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("book_series")
}

model BookSeriesItem {
  id        String  @id @default(ulid())
  seriesId  String
  productId String
  volumeNo  Int
  title     String?

  series  BookSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([seriesId, productId])
  @@unique([seriesId, volumeNo])
  @@index([seriesId])
  @@index([productId])
  @@map("book_series_items")
}

model Preorder {
  id               String  @id @default(ulid())
  userId           String
  branchId         String
  variantId        String
  quantity         Int
  status           String  @default("PENDING")
  note             String?
  convertedOrderId String?

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch         Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  convertedOrder Order?         @relation(fields: [convertedOrderId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([branchId])
  @@index([variantId])
  @@index([convertedOrderId])
  @@index([status])
  @@map("preorders")
}

model BookPreview {
  id        String  @id @default(ulid())
  productId String
  title     String?
  fileUrl   String?
  isActive  Boolean @default(true)

  product Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  pages   BookPreviewPage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([isActive])
  @@map("book_previews")
}

model BookPreviewPage {
  id        String @id @default(ulid())
  previewId String
  pageNo    Int
  imageUrl  String

  preview BookPreview @relation(fields: [previewId], references: [id], onDelete: Cascade)

  @@unique([previewId, pageNo])
  @@index([previewId])
  @@map("book_preview_pages")
}
