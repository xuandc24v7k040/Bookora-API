model BranchProductStock {
  id                String @id @default(ulid())
  branchId          String @map("branch_id")
  variantId         String @map("variant_id")
  quantity          Int    @default(0)
  reservedQuantity  Int    @default(0) @map("reserved_quantity")
  lowStockThreshold Int    @default(5) @map("low_stock_threshold")

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([branchId, variantId])
  @@index([branchId])
  @@index([variantId])
  @@map("branch_product_stocks")
}

model BranchProductPrice {
  id            String    @id @default(ulid())
  branchId      String    @map("branch_id")
  variantId     String    @map("variant_id")
  originalPrice Decimal   @map("original_price") @db.Decimal(12, 2)
  salePrice     Decimal?  @map("sale_price") @db.Decimal(12, 2)
  saleStartAt   DateTime? @map("sale_start_at")
  saleEndAt     DateTime? @map("sale_end_at")
  isActive      Boolean   @default(true) @map("is_active")

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([branchId, variantId])
  @@index([branchId])
  @@index([variantId])
  @@index([isActive])
  @@map("branch_product_prices")
}

model StockMovement {
  id             String            @id @default(ulid())
  branchId       String            @map("branch_id")
  variantId      String            @map("variant_id")
  performedById  String?           @map("performed_by_id")
  orderId        String?           @map("order_id")
  transferId     String?           @map("transfer_id")
  type           StockMovementType
  quantityBefore Int               @map("quantity_before")
  quantityChange Int               @map("quantity_change")
  quantityAfter  Int               @map("quantity_after")
  note           String?
  createdAt      DateTime          @default(now()) @map("created_at")

  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  performedBy User?          @relation("StockMovementPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  order       Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  transfer    StockTransfer? @relation(fields: [transferId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([variantId])
  @@index([branchId, variantId])
  @@index([performedById])
  @@index([orderId])
  @@index([transferId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model StockTransfer {
  id            String              @id @default(ulid())
  transferCode  String              @unique @map("transfer_code")
  fromBranchId  String              @map("from_branch_id")
  toBranchId    String              @map("to_branch_id")
  requestedById String?             @map("requested_by_id")
  approvedById  String?             @map("approved_by_id")
  shippedById   String?             @map("shipped_by_id")
  receivedById  String?             @map("received_by_id")
  cancelledById String?             @map("cancelled_by_id")
  status        StockTransferStatus @default(DRAFT)
  reason        String?
  note          String?
  requestedAt   DateTime?           @map("requested_at")
  approvedAt    DateTime?           @map("approved_at")
  shippedAt     DateTime?           @map("shipped_at")
  receivedAt    DateTime?           @map("received_at")
  cancelledAt   DateTime?           @map("cancelled_at")

  fromBranch  Branch @relation("StockTransferFromBranch", fields: [fromBranchId], references: [id])
  toBranch    Branch @relation("StockTransferToBranch", fields: [toBranchId], references: [id])
  requestedBy User?  @relation("StockTransferRequestedBy", fields: [requestedById], references: [id], onDelete: SetNull)
  approvedBy  User?  @relation("StockTransferApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  shippedBy   User?  @relation("StockTransferShippedBy", fields: [shippedById], references: [id], onDelete: SetNull)
  receivedBy  User?  @relation("StockTransferReceivedBy", fields: [receivedById], references: [id], onDelete: SetNull)
  cancelledBy User?  @relation("StockTransferCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)

  items     StockTransferItem[]
  movements StockMovement[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([transferCode])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_transfers")
}

model StockTransferItem {
  id           String                  @id @default(ulid())
  transferId   String                  @map("transfer_id")
  variantId    String                  @map("variant_id")
  requestedQty Int                     @map("requested_qty")
  shippedQty   Int                     @default(0) @map("shipped_qty")
  receivedQty  Int                     @default(0) @map("received_qty")
  status       StockTransferItemStatus @default(PENDING)
  note         String?

  transfer StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([transferId, variantId])
  @@index([transferId])
  @@index([variantId])
  @@index([status])
  @@map("stock_transfer_items")
}
