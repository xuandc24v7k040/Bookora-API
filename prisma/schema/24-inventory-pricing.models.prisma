model BranchProductStock {
  id                String @id @default(ulid())
  branchId          String
  variantId         String
  quantity          Int    @default(0)
  reservedQuantity  Int    @default(0)
  lowStockThreshold Int    @default(5)

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, variantId])
  @@index([branchId])
  @@index([variantId])
  @@map("branch_product_stocks")
}

model BranchProductPrice {
  id            String    @id @default(ulid())
  branchId      String
  variantId     String
  originalPrice Decimal   @db.Decimal(12, 2)
  salePrice     Decimal?  @db.Decimal(12, 2)
  saleStartAt   DateTime?
  saleEndAt     DateTime?
  isActive      Boolean   @default(true)

  branch  Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, variantId])
  @@index([branchId])
  @@index([variantId])
  @@index([isActive])
  @@map("branch_product_prices")
}

model StockMovement {
  id             String            @id @default(ulid())
  branchId       String
  variantId      String
  performedById  String?
  orderId        String?
  type           StockMovementType
  quantityBefore Int
  quantityChange Int
  quantityAfter  Int
  note           String?
  createdAt      DateTime          @default(now())

  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  performedBy User?          @relation("StockMovementPerformedBy", fields: [performedById], references: [id], onDelete: SetNull)
  order       Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([branchId])
  @@index([variantId])
  @@index([performedById])
  @@index([orderId])
  @@index([createdAt])
  @@map("stock_movements")
}
