model Order {
  id              String      @id @default(ulid())
  orderCode       String      @unique @map("order_code")
  userId          String      @map("user_id")
  branchId        String      @map("branch_id")
  couponId        String?     @map("coupon_id")
  status          OrderStatus @default(PENDING)
  subtotalAmount  Decimal     @map("subtotal_amount") @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  shippingFee     Decimal     @default(0) @map("shipping_fee") @db.Decimal(12, 2)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)
  receiverName    String      @map("receiver_name")
  receiverPhone   String      @map("receiver_phone")
  shippingAddress String      @map("shipping_address")
  note            String?

  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  coupon Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)

  items          OrderItem[]
  payment        Payment?
  shipment       OrderShipment?
  histories      OrderStatusHistory[]
  stockMovements StockMovement[]
  couponUsages   CouponUsage[]
  reviews        Review[]
  preorders      Preorder[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderCode])
  @@index([userId])
  @@index([branchId])
  @@index([couponId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id         String        @id @default(ulid())
  orderId    String        @map("order_id")
  variantId  String?       @map("variant_id")
  comboId    String?       @map("combo_id")
  itemType   OrderItemType @map("item_type")
  name       String
  sku        String?
  quantity   Int
  unitPrice  Decimal       @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal       @map("total_price") @db.Decimal(12, 2)
  createdAt  DateTime      @default(now()) @map("created_at")

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  combo   Combo?          @relation(fields: [comboId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
  @@index([comboId])
  @@map("order_items")
}

model Payment {
  id      String        @id @default(ulid())
  orderId String        @unique @map("order_id")
  method  PaymentMethod
  status  PaymentStatus @default(PENDING)
  amount  Decimal       @db.Decimal(12, 2)
  paidAt  DateTime?     @map("paid_at")

  order        Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transactions PaymentTransaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([method])
  @@index([status])
  @@map("payments")
}

model PaymentTransaction {
  id                  String                   @id @default(ulid())
  paymentId           String                   @map("payment_id")
  transactionType     PaymentTransactionType   @map("transaction_type")
  status              PaymentTransactionStatus @default(PENDING)
  gateway             String
  gatewayTxnRef       String?                  @map("gateway_txn_ref")
  gatewayOrderInfo    String?                  @map("gateway_order_info")
  gatewayResponseCode String?                  @map("gateway_response_code")
  gatewayMessage      String?                  @map("gateway_message")
  amount              Decimal                  @db.Decimal(12, 2)
  requestPayload      Json?                    @map("request_payload")
  responsePayload     Json?                    @map("response_payload")
  ipAddress           String?                  @map("ip_address")
  createdAt           DateTime                 @default(now()) @map("created_at")

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([gateway])
  @@index([gatewayTxnRef])
  @@index([status])
  @@map("payment_transactions")
}

model OrderShipment {
  id           String  @id @default(ulid())
  orderId      String  @unique @map("order_id")
  provider     String  @default("GHN")
  serviceCode  String? @map("service_code")
  shippingFee  Decimal @map("shipping_fee") @db.Decimal(12, 2)
  trackingCode String? @map("tracking_code")
  ghnOrderCode String? @map("ghn_order_code")
  status       String?
  rawResponse  Json?   @map("raw_response")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([provider])
  @@index([trackingCode])
  @@index([ghnOrderCode])
  @@index([status])
  @@map("order_shipments")
}

model OrderStatusHistory {
  id          String       @id @default(ulid())
  orderId     String       @map("order_id")
  oldStatus   OrderStatus? @map("old_status")
  newStatus   OrderStatus  @map("new_status")
  note        String?
  changedById String?      @map("changed_by_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy User? @relation("OrderStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([changedById])
  @@index([createdAt])
  @@map("order_status_histories")
}
