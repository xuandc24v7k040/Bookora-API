model Supplier {
  id      String  @id @default(ulid())
  name    String
  slug    String  @unique
  phone   String?
  email   String?
  address String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("suppliers")
}

model Publisher {
  id   String @id @default(ulid())
  name String
  slug String @unique

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("publishers")
}

model Author {
  id   String @id @default(ulid())
  name String
  slug String @unique

  products ProductAuthor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("authors")
}

model ProductAuthor {
  id        String @id @default(ulid())
  productId String
  authorId  String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  author  Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([productId, authorId])
  @@index([productId])
  @@index([authorId])
  @@map("product_authors")
}

model Product {
  id               String        @id @default(ulid())
  name             String
  slug             String        @unique
  description      String?
  shortDescription String?
  supplierId       String?
  publisherId      String?
  isbn             String?
  publicationYear  Int?
  pageCount        Int?
  weightGram       Int?
  packageSize      String?
  coverType        String?
  status           ProductStatus @default(DRAFT)
  releaseDate      DateTime?

  supplier  Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  publisher Publisher? @relation(fields: [publisherId], references: [id], onDelete: SetNull)

  categories      ProductCategory[]
  authors         ProductAuthor[]
  media           ProductMedia[]
  variants        ProductVariant[]
  attributeValues ProductAttributeValue[]
  reviews         Review[]
  wishlists       Wishlist[]
  relatedFrom     RelatedProduct[]        @relation("RelatedFrom")
  relatedTo       RelatedProduct[]        @relation("RelatedTo")
  seriesItems     BookSeriesItem[]
  previews        BookPreview[]
  couponProducts  CouponProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([supplierId])
  @@index([publisherId])
  @@index([status])
  @@index([slug])
  @@map("products")
}

model ProductMedia {
  id        String           @id @default(ulid())
  productId String
  type      ProductMediaType @default(IMAGE)
  url       String
  altText   String?
  sortOrder Int              @default(0)
  isPrimary Boolean          @default(false)
  createdAt DateTime         @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isPrimary, sortOrder])
  @@map("product_media")
}

model ProductOption {
  id        String @id @default(ulid())
  name      String
  code      String @unique
  sortOrder Int    @default(0)

  values ProductOptionValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_options")
}

model ProductOptionValue {
  id        String  @id @default(ulid())
  optionId  String
  label     String
  value     String
  colorCode String?
  imageUrl  String?
  sortOrder Int     @default(0)

  option       ProductOption               @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantLinks ProductVariantOptionValue[]

  @@unique([optionId, value])
  @@index([optionId])
  @@map("product_option_values")
}

model ProductVariant {
  id         String  @id @default(ulid())
  productId  String
  name       String
  sku        String  @unique
  barcode    String?
  imageUrl   String?
  weightGram Int?
  isDefault  Boolean @default(false)
  isActive   Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  optionValues   ProductVariantOptionValue[]
  media          ProductVariantMedia[]
  stocks         BranchProductStock[]
  prices         BranchProductPrice[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  comboItems     ComboItem[]
  stockMovements StockMovement[]
  preorders      Preorder[]
  couponProducts CouponProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([sku])
  @@index([isActive])
  @@map("product_variants")
}

model ProductVariantOptionValue {
  id            String @id @default(ulid())
  variantId     String
  optionValueId String

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([variantId])
  @@index([optionValueId])
  @@map("product_variant_option_values")
}

model ProductVariantMedia {
  id        String   @id @default(ulid())
  variantId String
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([isPrimary, sortOrder])
  @@map("product_variant_media")
}

model ProductAttribute {
  id   String               @id @default(ulid())
  name String
  code String               @unique
  type ProductAttributeType

  values ProductAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("product_attributes")
}

model ProductAttributeValue {
  id           String    @id @default(ulid())
  productId    String
  attributeId  String
  textValue    String?
  numberValue  Decimal?  @db.Decimal(12, 2)
  booleanValue Boolean?
  dateValue    DateTime?
  jsonValue    Json?

  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@index([textValue])
  @@index([numberValue])
  @@map("product_attribute_values")
}
