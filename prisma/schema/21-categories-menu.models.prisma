model Category {
  id          String       @id @default(ulid())
  name        String
  slug        String       @unique
  description String?
  parentId    String?      @map("parent_id")
  type        CategoryType @default(NORMAL)
  imageUrl    String?      @map("image_url")
  iconUrl     String?      @map("icon_url")
  isActive    Boolean      @default(true) @map("is_active")
  sortOrder   Int          @default(0) @map("sort_order")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  products         ProductCategory[]
  menuItems        MegaMenuItem[]
  filterSets       CategoryFilterSet[]
  couponCategories CouponCategory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([parentId])
  @@index([slug])
  @@index([isActive, sortOrder])
  @@map("categories")
}

model ProductCategory {
  id         String  @id @default(ulid())
  productId  String  @map("product_id")
  categoryId String  @map("category_id")
  isPrimary  Boolean @default(false) @map("is_primary")

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
  @@map("product_categories")
}

model MegaMenu {
  id          String  @id @default(ulid())
  name        String
  code        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")

  columns MegaMenuColumn[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive])
  @@map("mega_menus")
}

model MegaMenuColumn {
  id        String  @id @default(ulid())
  menuId    String  @map("menu_id")
  title     String?
  sortOrder Int     @default(0) @map("sort_order")

  menu     MegaMenu          @relation(fields: [menuId], references: [id], onDelete: Cascade)
  sections MegaMenuSection[]

  @@index([menuId])
  @@index([sortOrder])
  @@map("mega_menu_columns")
}

model MegaMenuSection {
  id        String  @id @default(ulid())
  columnId  String  @map("column_id")
  title     String
  titleUrl  String? @map("title_url")
  iconUrl   String? @map("icon_url")
  badge     String?
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  column MegaMenuColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  items  MegaMenuItem[]

  @@index([columnId])
  @@index([isActive, sortOrder])
  @@map("mega_menu_sections")
}

model MegaMenuItem {
  id         String           @id @default(ulid())
  sectionId  String           @map("section_id")
  categoryId String?          @map("category_id")
  type       MegaMenuItemType @default(CATEGORY)
  label      String
  url        String?
  badge      String?
  iconUrl    String?          @map("icon_url")
  sortOrder  Int              @default(0) @map("sort_order")
  isActive   Boolean          @default(true) @map("is_active")

  section  MegaMenuSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  category Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([sectionId])
  @@index([categoryId])
  @@index([isActive, sortOrder])
  @@map("mega_menu_items")
}
