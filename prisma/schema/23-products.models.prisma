model Supplier {
  id      String  @id @default(ulid())
  name    String
  slug    String  @unique
  phone   String?
  email   String?
  address String?

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("suppliers")
}

model Publisher {
  id   String @id @default(ulid())
  name String
  slug String @unique

  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("publishers")
}

model Author {
  id   String @id @default(ulid())
  name String
  slug String @unique

  products ProductAuthor[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("authors")
}

model ProductAuthor {
  id        String @id @default(ulid())
  productId String @map("product_id")
  authorId  String @map("author_id")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  author  Author  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@unique([productId, authorId])
  @@index([productId])
  @@index([authorId])
  @@map("product_authors")
}

model Product {
  id               String        @id @default(ulid())
  name             String
  slug             String        @unique
  description      String?
  shortDescription String?       @map("short_description")
  supplierId       String?       @map("supplier_id")
  publisherId      String?       @map("publisher_id")
  status           ProductStatus @default(DRAFT)
  releaseDate      DateTime?     @map("release_date")

  supplier  Supplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  publisher Publisher? @relation(fields: [publisherId], references: [id], onDelete: SetNull)

  categories      ProductCategory[]
  authors         ProductAuthor[]
  media           ProductMedia[]
  options         ProductOption[]
  variants        ProductVariant[]
  attributeValues ProductAttributeValue[]
  reviews         Review[]
  wishlists       Wishlist[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([supplierId])
  @@index([publisherId])
  @@index([status])
  @@index([slug])
  @@map("products")
}

model ProductMedia {
  id        String           @id @default(ulid())
  productId String           @map("product_id")
  variantId String?          @map("variant_id")
  type      ProductMediaType @default(IMAGE)
  url       String
  altText   String?          @map("alt_text")
  sortOrder Int              @default(0) @map("sort_order")
  isPrimary Boolean          @default(false) @map("is_primary")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@index([variantId, sortOrder])
  @@map("product_media")
}

model ProductOption {
  id        String @id @default(ulid())
  productId String @map("product_id")
  name      String
  code      String
  sortOrder Int    @default(0) @map("sort_order")

  product Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]
  links   ProductVariantOptionValue[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([productId, code])
  @@index([productId, sortOrder])
  @@map("product_options")
}

model ProductOptionValue {
  id        String  @id @default(ulid())
  optionId  String  @map("option_id")
  label     String
  value     String
  colorCode String? @map("color_code")
  imageUrl  String? @map("image_url")
  sortOrder Int     @default(0) @map("sort_order")

  option       ProductOption               @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantLinks ProductVariantOptionValue[]

  @@unique([optionId, value])
  @@index([optionId, sortOrder])
  @@map("product_option_values")
}

model ProductVariant {
  id              String    @id @default(ulid())
  productId       String    @map("product_id")
  name            String
  sku             String    @unique
  barcode         String?
  combinationKey  String    @map("combination_key")
  isbn            String?
  publicationYear Int?      @map("publication_year")
  pageCount       Int?      @map("page_count")
  weightGram      Int?      @map("weight_gram")
  packageSize     String?   @map("package_size")
  originalPrice   Decimal   @map("original_price") @db.Decimal(15, 2)
  salePrice       Decimal?  @map("sale_price") @db.Decimal(15, 2)
  saleStartAt     DateTime? @map("sale_start_at")
  saleEndAt       DateTime? @map("sale_end_at")
  isDefault       Boolean   @default(false) @map("is_default")
  isActive        Boolean   @default(true) @map("is_active")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  optionValues ProductVariantOptionValue[]
  media        ProductMedia[]
  stocks       BranchProductStock[]
  receiptItems StockReceiptItem[]
  cartItems    CartItem[]
  orderItems   OrderItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([productId, combinationKey])
  @@index([productId])
  @@index([productId, isDefault])
  @@index([sku])
  @@index([isActive])
  @@map("product_variants")
}

model ProductVariantOptionValue {
  id            String @id @default(ulid())
  variantId     String @map("variant_id")
  optionId      String @map("option_id")
  optionValueId String @map("option_value_id")

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  option      ProductOption      @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionId])
  @@unique([variantId, optionValueId])
  @@index([optionId])
  @@index([optionValueId])
  @@map("product_variant_option_values")
}

model ProductAttribute {
  id   String               @id @default(ulid())
  name String
  code String               @unique
  type ProductAttributeType

  values ProductAttributeValue[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("product_attributes")
}

model ProductAttributeValue {
  id           String    @id @default(ulid())
  productId    String    @map("product_id")
  attributeId  String    @map("attribute_id")
  textValue    String?   @map("text_value")
  numberValue  Decimal?  @map("number_value") @db.Decimal(12, 2)
  booleanValue Boolean?  @map("boolean_value")
  dateValue    DateTime? @map("date_value")
  jsonValue    Json?     @map("json_value")

  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@index([textValue])
  @@index([numberValue])
  @@map("product_attribute_values")
}
