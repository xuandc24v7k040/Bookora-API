model Coupon {
  id                String       @id @default(ulid())
  code              String       @unique
  name              String
  description       String?
  discountType      DiscountType
  discountValue     Decimal      @db.Decimal(12, 2)
  scope             CouponScope  @default(ALL_ORDER)
  minOrderAmount    Decimal?     @db.Decimal(12, 2)
  maxDiscount       Decimal?     @db.Decimal(12, 2)
  usageLimit        Int?
  usageLimitPerUser Int?
  usedCount         Int          @default(0)
  startAt           DateTime
  endAt             DateTime
  isActive          Boolean      @default(true)

  branches   CouponBranch[]
  products   CouponProduct[]
  categories CouponCategory[]
  usages     CouponUsage[]
  orders     Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([isActive, startAt, endAt])
  @@map("coupons")
}

model CouponBranch {
  id         String           @id @default(ulid())
  couponId   String
  branchId   String
  targetType CouponTargetType @default(INCLUDE)

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([couponId, branchId, targetType])
  @@index([couponId])
  @@index([branchId])
  @@map("coupon_branches")
}

model CouponProduct {
  id         String           @id @default(ulid())
  couponId   String
  productId  String?
  variantId  String?
  targetType CouponTargetType @default(INCLUDE)

  coupon  Coupon          @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([productId])
  @@index([variantId])
  @@map("coupon_products")
}

model CouponCategory {
  id              String           @id @default(ulid())
  couponId        String
  categoryId      String
  targetType      CouponTargetType @default(INCLUDE)
  includeChildren Boolean          @default(true)

  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([couponId, categoryId, targetType])
  @@index([couponId])
  @@index([categoryId])
  @@map("coupon_categories")
}

model CouponUsage {
  id             String   @id @default(ulid())
  couponId       String
  userId         String
  orderId        String?
  discountAmount Decimal  @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([userId])
  @@index([orderId])
  @@map("coupon_usages")
}
