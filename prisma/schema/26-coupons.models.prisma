model Coupon {
  id                String       @id @default(ulid())
  code              String       @unique
  name              String
  description       String?
  discountType      DiscountType @map("discount_type")
  discountValue     Decimal      @map("discount_value") @db.Decimal(12, 2)
  scope             CouponScope  @default(ALL_ORDER)
  minOrderAmount    Decimal?     @map("min_order_amount") @db.Decimal(12, 2)
  maxDiscount       Decimal?     @map("max_discount") @db.Decimal(12, 2)
  usageLimit        Int?         @map("usage_limit")
  usageLimitPerUser Int?         @map("usage_limit_per_user")
  usedCount         Int          @default(0) @map("used_count")
  startAt           DateTime     @map("start_at")
  endAt             DateTime     @map("end_at")
  isActive          Boolean      @default(true) @map("is_active")

  branches   CouponBranch[]
  products   CouponProduct[]
  categories CouponCategory[]
  usages     CouponUsage[]
  orders     Order[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code])
  @@index([isActive, startAt, endAt])
  @@map("coupons")
}

model CouponBranch {
  id         String           @id @default(ulid())
  couponId   String           @map("coupon_id")
  branchId   String           @map("branch_id")
  targetType CouponTargetType @default(INCLUDE) @map("target_type")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([couponId, branchId, targetType])
  @@index([couponId])
  @@index([branchId])
  @@map("coupon_branches")
}

model CouponProduct {
  id         String           @id @default(ulid())
  couponId   String           @map("coupon_id")
  productId  String?          @map("product_id")
  variantId  String?          @map("variant_id")
  targetType CouponTargetType @default(INCLUDE) @map("target_type")

  coupon  Coupon          @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([productId])
  @@index([variantId])
  @@index([targetType])
  @@index([couponId, productId, targetType])
  @@index([couponId, variantId, targetType])
  @@map("coupon_products")
}

model CouponCategory {
  id              String           @id @default(ulid())
  couponId        String           @map("coupon_id")
  categoryId      String           @map("category_id")
  targetType      CouponTargetType @default(INCLUDE) @map("target_type")
  includeChildren Boolean          @default(true) @map("include_children")

  coupon   Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([couponId, categoryId, targetType])
  @@index([couponId])
  @@index([categoryId])
  @@map("coupon_categories")
}

model CouponUsage {
  id             String   @id @default(ulid())
  couponId       String   @map("coupon_id")
  userId         String   @map("user_id")
  orderId        String?  @map("order_id")
  discountAmount Decimal  @map("discount_amount") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([userId])
  @@index([orderId])
  @@map("coupon_usages")
}
